# Copy this file to .env and fill in your Spotify Client ID
# Register your app at https://developer.spotify.com/dashboard
#
# REDIRECT URI SETUP (read carefully):
# 1. In Spotify dashboard -> Edit Settings -> Redirect URIs
# 2. Add exactly: http://127.0.0.1:5173/
#    (with trailing slash, using 127.0.0.1 not localhost)
# 3. Save changes
#
# Note: /callback route is NOT used — Spotify redirects to root
# and React reads the ?code= param from there.

VITE_SPOTIFY_CLIENT_ID=your_client_id_here
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/
